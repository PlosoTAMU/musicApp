rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Shared-secret model: the secret derives one Firebase account, so every
    // device of a home shares one uid. All state is that user's subtree.
    // Session fencing (epoch) is enforced client-side by transactions;
    // the server-side job is only isolation between accounts.
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
