rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Sessions ─────────────────────────────────────────────────────────
    match /sessions/{sid} {

      function isMember() {
        return request.auth != null && request.auth.uid in resource.data.members;
      }

      // A non-member's ONLY permitted write: append exactly themselves to
      // members (the pairing-code join). Everything else must be unchanged.
      function isSelfJoin() {
        return request.auth != null
          && !(request.auth.uid in resource.data.members)
          && request.resource.data.members.hasAll(resource.data.members)
          && request.auth.uid in request.resource.data.members
          && request.resource.data.members.size() == resource.data.members.size() + 1
          && request.resource.data.epoch == resource.data.epoch
          && request.resource.data.ownerDeviceID == resource.data.ownerDeviceID
          && request.resource.data.ownerUID == resource.data.ownerUID;
      }

      // Fencing is enforced client-side by transactions; the server-side
      // backstop is that epoch can never move backwards.
      function epochMonotonic() {
        return request.resource.data.epoch >= resource.data.epoch;
      }

      allow create: if request.auth != null
        && request.resource.data.ownerUID == request.auth.uid
        && request.resource.data.members == [request.auth.uid]
        && request.resource.data.epoch == 1;

      allow read: if isMember();
      allow update: if (isMember() && epochMonotonic()) || isSelfJoin();
      allow delete: if request.auth != null && request.auth.uid == resource.data.ownerUID;

      function parentMember() {
        return request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/sessions/$(sid)).data.members;
      }

      match /commands/{cid} {
        allow read, delete: if parentMember();
        allow create: if parentMember()
          && request.resource.data.by is string
          && request.resource.data.t in ['play', 'pause', 'next', 'prev', 'seek'];
      }

      match /presence/{deviceID} {
        allow read, write: if parentMember();
      }
    }

    // ── Pairing codes ────────────────────────────────────────────────────
    // Read/delete open to any signed-in user: redemption happens BEFORE
    // membership exists. Codes are 6-digit, single-use, 5-min TTL; the
    // deletion inside the redeem transaction closes the brute-force window.
    match /pairCodes/{code} {
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.sid is string;
      allow read, delete: if request.auth != null;
    }
  }
}
