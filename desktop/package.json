{
  "name": "pulsor-desktop",
  "version": "0.1.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "build": "tsc",
    "start": "tsc && electron .",
    "dist": "tsc && electron-builder --win"
  },
  "dependencies": {
    "firebase": "^10.12.0"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.0",
    "typescript": "^5.4.0"
  },
  "build": {
    "appId": "com.pulsor.desktop",
    "win": {
      "target": "nsis"
    },
    "files": [
      "main.js",
      "index.html",
      "dist/**",
      "node_modules/**"
    ]
  }
}
